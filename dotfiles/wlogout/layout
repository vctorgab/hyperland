{
    "label" : "lock",
    "action" : "hyprlock",
    "text" : "Bloquear (L)",
    "keybind" : "l"
}
{
    "label" : "logout",
    "action" : "hyprctl dispatch exit",
    "text" : "Cerrar Sesión (E)",
    "keybind" : "e"
}
{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "Apagar (S)",
    "keybind" : "s"
}
{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "Reiniciar (R)",
    "keybind" : "r"
}
{
    "label" : "suspend",
    "action" : "systemctl suspend",
    "text" : "Suspender (U)",
    "keybind" : "u"
}
